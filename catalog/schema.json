{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voice Catalog Entry",
  "description": "Unified schema for a TTS voice across any provider",
  "type": "object",
  "required": ["id", "provider", "provider_voice_id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ID in the format {provider}:{provider_voice_id}"
    },
    "provider": {
      "type": "string",
      "enum": ["elevenlabs", "cartesia", "deepgram", "openai", "playht", "rime"]
    },
    "provider_voice_id": {
      "type": "string",
      "description": "Original voice ID from the provider"
    },
    "provider_model": {
      "type": ["string", "null"],
      "description": "TTS model this voice works with (e.g. eleven_turbo_v2_5, sonic-2, aura-2)"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Human-readable description of the voice character"
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "neutral", "unknown"]
    },
    "age_group": {
      "type": "string",
      "enum": ["young", "middle", "mature", "unknown"]
    },
    "accent": {
      "type": ["string", "null"],
      "description": "e.g. american, british, australian, indian"
    },
    "language": {
      "type": "string",
      "description": "Primary language as BCP-47 code (e.g. en-US, es-MX, fr-FR)"
    },
    "additional_languages": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "traits": {
      "type": "object",
      "description": "Voice characteristics on a 0-1 scale. null = not yet classified.",
      "properties": {
        "warmth": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "energy": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "clarity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "authority": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "friendliness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "expressiveness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "pace": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "texture": {
      "type": ["string", "null"],
      "enum": ["smooth", "warm", "crisp", "gravelly", "breathy", "raspy", "rich", "thin", null]
    },
    "pitch": {
      "type": ["string", "null"],
      "enum": ["low", "medium-low", "medium", "medium-high", "high", null]
    },
    "speaking_style": {
      "type": ["string", "null"],
      "enum": [
        "conversational", "narration", "newscast", "customer_service",
        "meditation", "advertisement", "formal", "casual", null
      ]
    },
    "use_cases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. healthcare, sales, customer_support, education",
      "default": []
    },
    "personality_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "e.g. empathetic, professional, authoritative, playful",
      "default": []
    },
    "style_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form descriptors: raspy, deep, warm, crisp, soothing",
      "default": []
    },
    "emotional_range": {
      "type": ["string", "null"],
      "enum": ["static", "basic", "expressive", "full", null]
    },
    "supported_emotions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "latency_tier": {
      "type": ["string", "null"],
      "enum": ["fastest", "fast", "moderate", null]
    },
    "cost_per_min_usd": {
      "type": ["number", "null"],
      "description": "Cost per minute of generated audio in USD"
    },
    "preview_url": {
      "type": ["string", "null"],
      "description": "Direct URL to audio preview"
    },
    "provider_page_url": {
      "type": ["string", "null"],
      "description": "URL to hear/test this voice on the provider site"
    },
    "pipecat_supported": {
      "type": ["boolean", "null"],
      "description": "Whether this voice is usable via Pipecat"
    },
    "pipecat_class": {
      "type": ["string", "null"],
      "description": "Pipecat TTS service class name for this provider"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "preview"],
      "default": "active"
    },
    "metadata_source": {
      "type": "string",
      "enum": ["provider_api", "enriched_local", "enriched_cloud", "manual", "hybrid"],
      "description": "How the metadata was obtained"
    },
    "enrichment": {
      "type": ["object", "null"],
      "description": "Details about LLM/acoustic enrichment applied to this entry",
      "properties": {
        "model": {
          "type": "string",
          "description": "Model used for enrichment (e.g. gpt-4o, claude-3.5-sonnet)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sample_text": {
          "type": "string",
          "description": "Text used to generate the sample for acoustic analysis"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of enrichment"
        },
        "acoustic": {
          "type": "object",
          "description": "Acoustic measurements from the generated sample",
          "properties": {
            "f0_mean_hz": { "type": ["number", "null"] },
            "f0_std_semitones": { "type": ["number", "null"] },
            "hnr_db": { "type": ["number", "null"] },
            "speaking_rate_sps": { "type": ["number", "null"] },
            "spectral_centroid": { "type": ["number", "null"] },
            "h1_h2_db": { "type": ["number", "null"] },
            "jitter_pct": { "type": ["number", "null"] },
            "shimmer_db": { "type": ["number", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "last_synced": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last provider sync"
    },
    "last_verified": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last verification"
    },
    "provider_metadata": {
      "type": "object",
      "description": "Raw provider-specific fields that are not normalized",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
